# ==============================================
# APPLICATION SETTINGS
# ==============================================
APP_NAME="JastipHype"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ==============================================
# LOGGING
# ==============================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================
# DATABASE - LOCAL (MySQL)
# ==============================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jastiphype
DB_USERNAME=root
DB_PASSWORD=

# ==============================================
# DATABASE - PRODUCTION (PostgreSQL Railway)
# Uncomment untuk production/testing dengan Railway
# ==============================================
# DB_CONNECTION=pgsql
# DB_HOST=your-railway-host.railway.app
# DB_PORT=5432
# DB_DATABASE=railway
# DB_USERNAME=postgres
# DB_PASSWORD=your-railway-password

# ==============================================
# SESSION & CACHE
# ==============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# ==============================================
# QUEUE & BROADCAST
# ==============================================
BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database

# ==============================================
# FILE STORAGE
# ==============================================
FILESYSTEM_DISK=public

# ==============================================
# REDIS (Optional)
# ==============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ==============================================
# MAIL SETTINGS
# ==============================================
# Local Development (Log)
MAIL_MAILER=log

# Production/Testing (Mailtrap)
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="noreply@jastiphype.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==============================================
# MIDTRANS PAYMENT GATEWAY
# ==============================================
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ==============================================
# RAJAONGKIR SHIPPING API
# ==============================================
RAJAONGKIR_API_KEY=your-rajaongkir-api-key

# ==============================================
# OAUTH - GOOGLE
# ==============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8000/auth/google/callback

# ==============================================
# OAUTH - FACEBOOK
# ==============================================
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=http://localhost:8000/auth/facebook/callback

# ==============================================
# AWS S3 (Optional - untuk production file storage)
# ==============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==============================================
# VITE
# ==============================================
VITE_APP_NAME="${APP_NAME}"
